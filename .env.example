# =============================================================================
# Budget Analyzer - Local Development Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Tilt reads this file for both local secret generation and local non-secret
# config rendering. Values are classified before they become Kubernetes
# objects; ".env input" does not automatically mean "Kubernetes Secret".
#
# IMPORTANT: Never commit .env to version control!
# =============================================================================

# =============================================================================
# Infrastructure Credential Contract (Local Kind Only)
# =============================================================================
# Step 1 froze the secret names and keys. PostgreSQL Step 2 now uses a separate
# bootstrap admin identity plus one database user per consuming service.

# PostgreSQL bootstrap/admin password for the postgres_admin superuser.
POSTGRES_BOOTSTRAP_PASSWORD=budget-analyzer-postgres-admin

# PostgreSQL service-user passwords. The usernames are fixed in manifests:
# transaction_service, currency_service, permission_service.
POSTGRES_TRANSACTION_SERVICE_PASSWORD=budget-analyzer-transaction-service
POSTGRES_CURRENCY_SERVICE_PASSWORD=budget-analyzer-currency-service
POSTGRES_PERMISSION_SERVICE_PASSWORD=budget-analyzer-permission-service

# RabbitMQ admin password for the fixed rabbitmq-admin user. Step 3 loads this
# and the currency-service user from a boot-time definitions file.
RABBITMQ_BOOTSTRAP_PASSWORD=budget-analyzer-rabbitmq-admin

# RabbitMQ service-user password for the fixed currency-service user.
RABBITMQ_CURRENCY_SERVICE_PASSWORD=budget-analyzer-currency-service-rabbitmq

# Redis default-user password. This identity is intentionally restricted to
# `PING` + `AUTH` so Kubernetes probes still work after ACL hardening.
REDIS_DEFAULT_PASSWORD=budget-analyzer-redis-default

# Redis ACL user passwords.
REDIS_OPS_PASSWORD=budget-analyzer-redis-ops
REDIS_SESSION_GATEWAY_PASSWORD=budget-analyzer-session-gateway-redis
REDIS_EXT_AUTHZ_PASSWORD=budget-analyzer-ext-authz-redis
REDIS_CURRENCY_SERVICE_PASSWORD=budget-analyzer-currency-service-redis

# =============================================================================
# Auth0 Session Gateway Inputs
# =============================================================================
# Get these values from your Auth0 dashboard:
# https://manage.auth0.com/dashboard
# Applications > budget-analyzer-web > Settings

# Non-secret issuer URI. Tilt renders this into ConfigMap/session-gateway-idp-config,
# and the Istio Auth0 egress allowlist derives the hostname from the same value.
AUTH0_ISSUER_URI=https://your-tenant.us.auth0.com/

# Non-secret client ID rendered into ConfigMap/session-gateway-idp-config.
AUTH0_CLIENT_ID=your-auth0-client-id

# Secret client secret rendered into Secret/auth0-credentials.
AUTH0_CLIENT_SECRET=your-auth0-client-secret

# Optional non-secret Auth0/API overrides. The defaults below match local development.
# Audience used by Session Gateway when requesting access tokens from Auth0.
# IDP_AUDIENCE=https://api.budgetanalyzer.org

# Non-secret post-logout redirect target handled by Session Gateway.
# Must also be allowed in the Auth0 application logout settings.
# IDP_LOGOUT_RETURN_TO=https://app.budgetanalyzer.localhost/peace

# Shared session-contract vars such as SESSION_KEY_PREFIX and
# SESSION_COOKIE_NAME remain intentionally unsurfaced here. Those defaults are
# verified across Session Gateway and ext-authz instead.

# =============================================================================
# External API Keys
# =============================================================================

# FRED API Key (Federal Reserve Economic Data)
# Get your free API key from: https://fred.stlouisfed.org/docs/api/api_key.html
# Used by currency-service for exchange rate data
FRED_API_KEY=your-fred-api-key
